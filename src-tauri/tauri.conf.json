{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KiJi",
  "version": "0.1.0",
  "identifier": "com.yomilab.kiji",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "KiJi",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "active",
          "radius": 14
        }
      },
      {
        "label": "settings",
        "title": "KiJi Settings",
        "url": "index.html?window=settings",
        "width": 700,
        "height": 660,
        "visible": false,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["underWindowBackground"],
          "state": "active",
          "radius": 14
        }
      },
      {
        "label": "article",
        "create": false,
        "title": "KiJi Article",
        "url": "index.html?window=article",
        "width": 1000,
        "height": 720,
        "visible": false,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["underWindowBackground"],
          "state": "active",
          "radius": 14
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "icons/": "icons",
      "icons-dark/": "icons-dark"
    },
    "icon": [
      "icons-dark/32x32.png",
      "icons-dark/128x128.png",
      "icons-dark/128x128@2x.png",
      "icons-dark/icon.icns",
      "icons-dark/icon.ico"
    ]
  }
}
