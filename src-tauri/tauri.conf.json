{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KiJi",
  "version": "0.1.0",
  "identifier": "com.yomilab.kiji",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KiJi",
        "width": 800,
        "height": 600
      },
      {
        "label": "settings",
        "title": "KiJi Settings",
        "url": "index.html?window=settings",
        "width": 700,
        "height": 660,
        "visible": false,
        "resizable": false
      },
      {
        "label": "article",
        "title": "KiJi Article",
        "url": "index.html?window=article",
        "width": 1000,
        "height": 720,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
